---
const hasToc = Astro.locals.starlightRoute.toc;
---
<div class="lg:sl-flex">
	<!-- Always render the right column at 72rem+ so layout stays consistent with or without TOC -->
	<aside class="right-sidebar-container print:hidden" class:list={{ 'right-sidebar-container--empty': !hasToc }}>
		<div class="right-sidebar">
			{hasToc && <slot name="right-sidebar" />}
		</div>
	</aside>
	<div class="main-pane"><slot /></div>
</div>

<style>
	@layer starlight.core {
		.main-pane {
			isolation: isolate;
		}

		@media (min-width: 72rem) {
			.right-sidebar-container {
				order: 2;
				position: relative;
				width: calc(
					var(--sl-sidebar-width) + (100% - var(--sl-content-width) - var(--sl-sidebar-width)) / 2
				);
			}

			.right-sidebar {
				position: fixed;
				top: 0;
				border-inline-start: 1px solid var(--sl-color-hairline);
				padding-top: var(--sl-nav-height);
				width: 100%;
				height: 100vh;
				overflow-y: auto;
				scrollbar-width: none;
			}

			.right-sidebar-container--empty .right-sidebar {
				border-inline-start: none;
			}

			.main-pane {
				order: 1;
				width: calc(
					var(--sl-content-width) + (100% - var(--sl-content-width) - var(--sl-sidebar-width)) / 2
				);
				--sl-content-margin-inline: auto 0;
			}
		}
	}
</style>
