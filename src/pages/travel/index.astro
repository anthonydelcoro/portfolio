---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import { Image } from 'astro:assets';
import { getAlbums } from '../../utils/albums';

const albums = await getAlbums();
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<StarlightPage frontmatter={{ title: 'Travel', tableOfContents: false }}>
  <div class="gallery-page">
    <p>These are some of the places I have vistied over the years and the photos I took.</p>
    {albums.length > 0 ? (
      <div class="gallery-grid">
        {albums.map((album) => (
          <a href={`${base}/travel/${album.id}/`} class="gallery-card">
            <Image
              src={album.thumbnail}
              alt={album.title}
              width={600}
              quality="mid"
              class="gallery-thumbnail"
            />
            <div class="gallery-card-info">
              <strong>{album.title}</strong>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <p class="gallery-empty">
        No albums found. Add photos to <code>src/assets/travel/&lt;album-name&gt;/</code> to get started.
      </p>
    )}
  </div>
</StarlightPage>
